# build output 编译产物
dist/

# generated types Astro缓存目录
.astro/

# dependencies 超大依赖目录（核心，解决EdgeOne文件超限）
node_modules/

# logs 各类包管理器日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables 隐私环境变量
.env
.env.production
.env*

# macOS系统垃圾文件
.DS_Store

# Vercel本地配置缓存
.vercel

# IDE配置目录
.idea/
*.iml
.claude

# 项目文档/本地资源
Firefly-docs/
cache/
package/
.obsidian/

# Python
__pycache__/
*.pyc
fir/
.wrangler/
