---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { externalMomentsConfig } from "@/config";
import { siteConfig } from "@/config";

if (!siteConfig.pages.talks) {
  return Astro.redirect("/404/");
}

const enabled = externalMomentsConfig.enable;
---

<MainGridLayout
  title={i18n(I18nKey.talks)}
  description={i18n(I18nKey.talksDescription)}
>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      {enabled ? (
        <div id="moments-container" class="moments-container">
          <div id="moments-loading" class="moments-loading">
            <div class="moments-spinner"></div>
            <span>加载中...</span>
          </div>
          <div id="moments-list" class="moments-list"></div>
          <div id="moments-empty" class="moments-empty" style="display:none;">
            <p>暂无说说</p>
          </div>
          <div id="moments-error" class="moments-error" style="display:none;">
            <p>加载失败，请稍后再试</p>
          </div>
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-50 text-sm">说说功能未启用</p>
        </div>
      )}
    </div>
  </div>

  {enabled && (
    <div class="mt-4 text-center">
      <a href="/admin/moments/" class="btn-regular inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm">
        <span>✏️</span>
        <span>管理说说</span>
      </a>
    </div>
  )}
</MainGridLayout>

{enabled && (
  <script is:inline define:vars={{ gistId: externalMomentsConfig.gistId, fileName: externalMomentsConfig.fileName }}>
    function initMoments() {
      var loading = document.getElementById("moments-loading");
      var list = document.getElementById("moments-list");
      var empty = document.getElementById("moments-empty");
      var error = document.getElementById("moments-error");

      if (!list) return;

      // 直接通过 API 获取公开 Gist（不带 Token 更快）
      var apiUrl = "https://api.github.com/gists/" + gistId;

      fetch(apiUrl)
        .then(function(res) {
          if (!res.ok) throw new Error("HTTP " + res.status);
          return res.json();
        })
        .then(function(gist) {
          var fileContent = gist.files[fileName];
          if (!fileContent) throw new Error("File not found in Gist");
          var moments = JSON.parse(fileContent.content);

          if (!Array.isArray(moments) || moments.length === 0) {
            loading.style.display = "none";
            empty.style.display = "block";
            return;
          }

          // Sort by date descending, pinned first
          moments.sort(function(a, b) {
            if (a.pinned && !b.pinned) return -1;
            if (!a.pinned && b.pinned) return 1;
            return new Date(b.published) - new Date(a.published);
          });

          loading.style.display = "none";
          list.style.display = "block";

          moments.forEach(function(m) {
            var card = document.createElement("div");
            card.className = "moment-card";

            var date = new Date(m.published);
            var dateStr = date.getFullYear() + "-" +
              String(date.getMonth() + 1).padStart(2, "0") + "-" +
              String(date.getDate()).padStart(2, "0") + " " +
              String(date.getHours()).padStart(2, "0") + ":" +
              String(date.getMinutes()).padStart(2, "0");

            var imagesHtml = "";
            if (m.images && m.images.length > 0) {
              imagesHtml = '<div class="moment-images">' +
                m.images.map(function(img) {
                  return '<img src="' + img + '" alt="说说图片" loading="lazy" />';
                }).join("") + '</div>';
            }

            var tagsHtml = "";
            if (m.tags && m.tags.length > 0) {
              tagsHtml = '<div class="moment-tags">' +
                m.tags.map(function(tag) {
                  return '<span class="moment-tag">' + tag + '</span>';
                }).join("") + '</div>';
            }

            var locationHtml = "";
            if (m.location) {
              locationHtml = '<span class="moment-location">📍 ' + m.location + '</span>';
            }

            var pinnedHtml = "";
            if (m.pinned) {
              pinnedHtml = '<span class="moment-pinned">置顶</span>';
            }

            card.innerHTML =
              '<div class="moment-header">' +
                '<div class="moment-meta">' +
                  '<span class="moment-date">' + dateStr + '</span>' +
                  locationHtml +
                  pinnedHtml +
                '</div>' +
              '</div>' +
              '<div class="moment-content">' + m.content + '</div>' +
              imagesHtml +
              tagsHtml;

            list.appendChild(card);
          });
        })
        .catch(function(err) {
          console.error("Failed to load moments:", err);
          loading.style.display = "none";
          error.style.display = "block";
        });
    }

    initMoments();
    document.addEventListener("astro:page-load", initMoments);
    document.addEventListener("swup:contentReplaced", initMoments);
  </script>
)}
